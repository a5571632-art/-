  - {name: 🇺🇲 美国节点, type: select, proxies: [⚡ 美国自动], include-all: true, filter: "(?i)美国|us|united states" }
  - {name: 🕊️ 冷门节点, type: select, include-all: true, filter: "(?i)^(?!.*(港|hk|hongkong|hong kong|台|twn|taiwan|台北|高雄|日|jp|japan|新|sg|singapore|韩|kr|korea|美|us|united states|流量|套餐|官网|刷新|异常|重置)).*$" }

