  - {name: 🇨🇳 台湾节点, type: select, proxies: [⚡ 台湾自动], include-all: true, filter: "(?i)台湾|twn|taiwan|台北|高雄" }
  - {name: 🇯🇵 日本节点, type: select, proxies: [⚡ 日本自动], include-all: true, filter: "(?i)日本|jp|japan" }
