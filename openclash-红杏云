  - {name: 📹 YouTube, <<: *pr}
  - {name: 🍀 Google, type: select, proxies: [🍀 Google自动, 🚀 节点选择, 🇨🇳 台湾节点, 🇯🇵 日本节点, 🇺🇲 美国节点, 🇭🇰 香港节点, 🇸🇬 加坡节点, 🕊️ 冷门节点, 🌐 全部节点, 🟢 直连]}
  - {name: 🎮️ Steam, <<: *pr}
  - {name: 🤖 AI服务, <<: *pr}
  - {name: 💬 ChatGPT, <<: *pr}
  - {name: Ⓜ️ Copilot, <<: *pr}
  - {name: 📢 谷歌FCM, <<: *pr}
  - {name: 👨🏿‍💻 GitHub, <<: *pr}
