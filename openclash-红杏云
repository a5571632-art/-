#基础配置
# 日期：2025-1-23 (于 2026-05 修复连环 QoS 阻断问题)
# 作者：lin (Modified by AI)
# 适用版本：适配使用mihomo内核的程序

# 锚点 (还原为你最开始的配置)
pr: &pr {type: select, proxies: [🚀 节点选择, ♻️ 自动切换, 🇭🇰 香港节点, 🇨🇳 台湾节点, 🇯🇵 日本节点, 🇸🇬 加坡节点,  🇺🇲 美国节点, 🕊️ 冷门节点, 🌐 全部节点, 🟢 直连]}
pe: &pe {type: select, proxies: [🟢 直连, 🚀 节点选择, ♻️ 自动切换, 🇭🇰 香港节点, 🇨🇳 台湾节点, 🇯🇵 日本节点, 🇸🇬 加坡节点, 🇺🇲 美国节点, 🕊️ 冷门节点, 🌐 全部节点]}

# 机场订阅
proxy-providers:
  红杏加速器:
    type: http
    interval: 21600
    health-check:
      enable: true
      url: https://www.gstatic.com/generate_204
      interval: 300
    url: "https://admin.hongxingyunchange.com/sub?target=clash&url=https%3A%2F%2F106.55.228.246%3A36666%2Fhxvip%3Ftoken%3Df15db81f831b5085126b9a1debeec849&config=https%3A%2F%2Fraw.githubusercontent.com%2Flinhaixueyuan33%2Fxueyuan%2Frefs%2Fheads%2Fmain%2Frule%2Fclash_config.ini"
  
# 用于下载订阅时指定UA
global-ua: clash.meta

# 全局配置
port: 7890
socks-port: 7891
redir-port: 7892
mixed-port: 7893
tproxy-port: 7894
log-level: info
ipv6: true
allow-lan: true
unified-delay: true   # 统一延迟
tcp-concurrent: true

geodata-mode: false

geodata-loader: standard
geo-auto-update: true
geo-update-interval: 24
geox-url:
  # 修复：更换稳定加速源
  geosite: "https://ghp.ci/https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat"
  mmdb: "https://ghp.ci/https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip-lite.metadb"
  geoip: "https://ghp.ci/https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip-lite.dat"
  asn: "https://ghp.ci/https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/GeoLite2-ASN.mmdb"

find-process-mode: strict
global-client-fingerprint: chrome
keep-alive-idle: 600
keep-alive-interval: 30

profile:
  store-selected: true
  store-fake-ip: true

sniffer:
  enable: true
  force-dns-mapping: true
  parse-pure-ip: true
  override-destination: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]
  force-domain:
    - +.v2ex.com
  skip-domain:
    - "Mijia Cloud"
    - "dlg.io.mi.com"
    - "+.push.apple.com"
    - "+.apple.com"

# DNS模块
dns:
  enable: true
  listen: 0.0.0.0:53
  ipv6: false
  respect-rules: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.0/15
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - geosite:private
    - geosite:cn
    - "+.lan"
    - "connect.rom.miui.com"
    - "+.miwifi.com"
    - "+.ntp.org"
    - "+.u-tools.cn"
    - "+.mediatek.com"
    - "+.cfprefer1.xyz"
    - "+.wetab.link"
    # QQ
    - "localhost.ptlogin2.qq.com"
    - "localhost.sec.qq.com"
    # WeChat
    - "localhost.work.weixin.qq.com"
    - "+.weixin.qq.com"
    - "+.wechat.com"
    # Windows
    - "time.windows.com"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "+.wpsmail.net"
    - "+.henzanapp.com"
    - "+.pconline.com.cn"
  
  nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query

  proxy-server-nameserver:
    - https://dns.alidns.com/dns-query
    # 修复：必须保留可靠的外部 DNS 用于解析代理节点自身的域名
    - https://1.1.1.1/dns-query

  fallback:
    # 修复：fallback 恢复纯净海外 DNS，确保不被国内投毒
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4

  nameserver-policy:
    "geosite:cn,private":
      - https://dns.alidns.com/dns-query
      - https://doh.pub/dns-query

proxies:
  - name: "🟢 直连"
    type: direct
    udp: true

# 策略组 (晚高峰抗压版：极致省流 + 容忍网络拥堵)
proxy-groups:
  # 【总控制台】这是你平时操作的地方
  - {name: 🚀 节点选择, type: select, proxies: [♻️ 自动切换, 🇭🇰 香港节点, 🇨🇳 台湾节点, 🇯🇵 日本节点, 🇸🇬 加坡节点, 🇺🇲 美国节点, 🕊️ 冷门节点, 🌐 全部节点, 🟢 直连]}
  
  # 【后台故障转移组-异常自动跳】(去除原先卡就跳的url-test，统一用fallback)
  - {name: ⚡ 台湾自动, type: fallback, include-all: true, filter: "(?i)台湾|twn|taiwan|台北|高雄", timeout: 800, interval: 60, lazy: true, url: "https://www.gstatic.com/generate_204" }
  - {name: ⚡ 香港自动, type: fallback, include-all: true, filter: "(?i)香港|hk|hongkong|hong kong", timeout: 800, interval: 60, lazy: true, url: "https://www.gstatic.com/generate_204" }
  - {name: ⚡ 日本自动, type: fallback, include-all: true, filter: "(?i)日本|jp|japan", timeout: 1000, interval: 60, lazy: true, url: "https://www.gstatic.com/generate_204" }
  - {name: ⚡ 新加坡自动, type: fallback, include-all: true, filter: "(?i)新加坡|sg|singapore", timeout: 1000, interval: 60, lazy: true, url: "https://www.gstatic.com/generate_204" }
  - {name: ⚡ 美国自动, type: fallback, include-all: true, filter: "(?i)美国|us|united states", timeout: 1500, interval: 60, lazy: true, url: "https://www.gstatic.com/generate_204" }

  # 【跨区自动切换】
  - {name: ♻️ 自动切换, type: fallback, proxies: [⚡ 台湾自动, ⚡ 香港自动, ⚡ 新加坡自动], timeout: 1200, interval: 60, lazy: true, url: "https://www.gstatic.com/generate_204"}

  # ===== 【Google专属策略组】 =====
