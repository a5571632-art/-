# --- 2. 抓取时间与局域网设备数据 ---
# 获取当前时间
CURRENT_TIME=$(date "+%Y-%m-%d %H:%M:%S")

# 【轻量优化】不保存大变量，直接流式提取，保护软路由内存
# 提取排名前 5 的活跃设备 IP (过滤掉本机)并转为单行
ACTIVE_IPS=$(curl -s -H "Authorization: Bearer $CLASH_SECRET" http://127.0.0.1:9090/connections | grep -oE '"sourceIP":"[^"]+"' | cut -d'"' -f4 | grep -v "127.0.0.1" | sort | uniq -c | sort -nr | head -n 5 | tr '\n' ',' | sed 's/,$//')

# 提取排名前 10 的活跃域名并转为单行
DOMAINS_CLEAN=$(curl -s -H "Authorization: Bearer $CLASH_SECRET" http://127.0.0.1:9090/connections | grep -oE '"host":"[^"]+"' | cut -d'"' -f4 | grep -v "^$" | sort | uniq -c | sort -nr | head -n 10 | tr '\n' ',' | sed 's/,$//')

if [ -z "$DOMAINS_CLEAN" ]; then
    echo "当前无活跃连接，跳过分析。"
    exit 0
fi

# --- 3. 调用 AI 进行深度风控分析 ---
# 结构化 Prompt，强制 AI 进行逐机画像与流量异常判定
PROMPT="你是一位家庭网络风控专家。当前时间是：${CURRENT_TIME}。目前活跃设备IP及连接数：${ACTIVE_IPS}；主要访问域名：${DOMAINS_CLEAN}。请完成以下两项任务：\\n1. 【逐机动态画像】：分点列出，结合域名特征推测每个IP具体在做什么。你可以代入家庭场景进行逻辑推演，例如是否是大人在处理工作，或者女儿在看视频。\\n2. 【流量异常评估】：结合当前时间与连接数，明确给出当前流量状态的定性（正常 / 疑似异常），并简述风控判断理由（如：深夜突发大流量、异常未知请求等）。\\n注意：严禁出现双引号，排版要清晰可读，可适当使用Emoji。"

AI_PAYLOAD=$(printf '{"model": "deepseek-v3-0324", "messages": [{"role": "user", "content": "%s"}]}' "$PROMPT")

# 【直连优化】删除 -x 代理参数，走国内宽带直连，增加 5 秒超时防卡死
RAW_AI_REPLY=$(curl -k --connect-timeout 5 -s "$AI_URL" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $AI_API_KEY" \
  -d "$AI_PAYLOAD")

# 提取 AI 的回答内容
FINAL_MSG=$(echo "$RAW_AI_REPLY" | awk -F'"content":"' '{print $2}' | awk -F'"' '{print $1}')

if [ -z "$FINAL_MSG" ]; then
    FINAL_MSG="AI未返回有效内容，原始数据：$RAW_AI_REPLY"
fi

# 剔除双引号和换行符 (保留 JSON 格式)
FINAL_MSG_SAFE=$(echo "$FINAL_MSG" | tr -d '"' | tr -d '\n' | tr -d '\r')
